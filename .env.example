# .env.example – copy to .env and fill in real values.
# .env is gitignored and must never be committed.

# A strong random secret used to authenticate API requests.
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
DISPATCHER_API_KEY=

# Comma-separated list of host paths that jobs are allowed to bind-mount.
# Example: /mnt/caas-data,/data
ALLOWED_HOST_DIRS=

# Set to true on GPU machines to enable GPU job support.
# Requires nvidia-container-toolkit installed on the host (see ansible/playbook.yml).
# CAAS_GPU_ENABLED=false
