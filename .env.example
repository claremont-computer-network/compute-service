# .env.example – copy to .env and fill in real values.
# .env is gitignored and must never be committed.

# A strong random secret used to authenticate API requests.
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
DISPATCHER_API_KEY=

# Comma-separated list of host paths that jobs are allowed to bind-mount.
# Example: /mnt/caas-data,/data
ALLOWED_HOST_DIRS=

# Persistent data directory for the dispatcher's file-based stores
# (templates, schedules, staging areas, configs). Mounted as a named
# Docker volume. Default: /srv/caas-data
CAAS_DATA_DIR=/srv/caas-data

# GPU job support is controlled at provisioning time via Ansible (caas_gpu_enabled
# in group_vars/all.yml), not via an environment variable here.
# The dispatcher will pass GPU requests through to Docker automatically when a job
# includes the "gpu" field, provided nvidia-container-toolkit is installed on the host.
# See ansible/vars.example.yml and ansible/playbook.yml for GPU provisioning options.
